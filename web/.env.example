# ─────────────────────────────────────────────────────────────────────────────
# Wispal env. Leave EVERYTHING blank to run fully local-first as a guest (no cloud).
# Fill these in (and apply supabase/migrations/0001_init.sql to your project) to
# light up auth + cloud sync. The app degrades gracefully when they are absent.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe for the browser; RLS enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Where the app is reachable (used by the extension build + auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# VAPID public key for web push (optional; push send is deferred in V1)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
